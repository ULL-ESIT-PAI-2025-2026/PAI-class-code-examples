{
  "display": "Object Oriented multiple present application",
  "compilerOptions": {
    "target": "es2015",
    "module": "es2015",
    "rootDir": "./",
    "outDir": "./",
    "declaration": false,                     
    "alwaysStrict": true,                     
    "strict": true,                           
    "lib": ["ESNext", "dom"],                 
    "noImplicitAny": true,                    
    "noFallthroughCasesInSwitch": true,       
    "noImplicitReturns": true,                
    "forceConsistentCasingInFileNames": true  
  },
  "exclude": [
        "node_modules",
        "build",
        "lib",
        "test",
        "public"
  ]
}
